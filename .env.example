# Supabase (Base de données)
# Obtenir les clés sur: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Anthropic (Claude claude-sonnet-4-5)
# Obtenir une clé sur: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# TMDB (The Movie Database)
# Obtenir une clé API sur: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# Server
PORT=5000
NODE_ENV=development

# MovieHunt
MOVIEHUNT_URL=https://moviehunt.fr

# Webhook (secret partagé pour authentifier les appels POST /api/webhook/moviehunt)
# Générer avec : openssl rand -hex 32
WEBHOOK_SECRET=your_long_random_webhook_secret_here

# On-Demand Revalidation Next.js (ISR)
# Générer avec : openssl rand -hex 32
# ⚠️  À définir AUSSI dans les env vars Vercel du projet moviehunt-blog (client)
REVALIDATION_SECRET=your_revalidation_secret_here
NEXT_SITE_URL=https://www.moviehunt-blog.fr

# Frontend URL (pour CORS)
CLIENT_URL=http://localhost:5173

# Frontend Supabase (pour l'authentification)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
